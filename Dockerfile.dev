# syntax=docker/dockerfile:1
FROM oven/bun:latest

ENV DEBIAN_FRONTEND=noninteractive \
    PATH="/root/.cargo/bin:$PATH"

# Configure apt to allow BuildKit caching
RUN rm -f /etc/apt/apt.conf.d/docker-clean; echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' > /etc/apt/apt.conf.d/keep-cache

# 1. Mount apt caches and use --no-install-recommends
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt \
    apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential pkg-config file imagemagick \
    libssl-dev libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev librsvg2-dev \
    libsecret-1-dev libdbus-1-dev \
    xvfb x11-utils

# 2. Cache the Rust installation downloads
RUN --mount=type=cache,target=/root/.rustup \
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

WORKDIR /app

EXPOSE 1420

CMD ["sh", "-c", "\
  mkdir -p src-tauri/icons && \
  convert -size 512x512 xc:'rgba(26,26,46,255)' PNG32:src-tauri/icons/icon.png && \
  bun install && \
  if xdpyinfo -display \"${DISPLAY:-:0}\" >/dev/null 2>&1; then \
    bun run tauri dev; \
  else \
    xvfb-run --auto-servernum --server-args='-screen 0 1920x1080x24' bun run tauri dev; \
  fi"]